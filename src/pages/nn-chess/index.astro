---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Board from '../../../nn-chess/ui/Board.tsx';
---
<BaseLayout title="nn-chess" description="Browser chess that learns from self-play" useMath={false}>
  <h1>nn-chess</h1>
  <p>
    This is an early prototype — you are playing <em>against yourself</em> to
    verify the board wiring works end to end. A neural-network agent that
    learns purely from win/loss signal (no hand-coded evaluation) will be
    plugged in during a later iteration. See the{' '}
    <a href="https://github.com/lucaswiman/lucaswiman.github.io/blob/main/nn-chess/README.md">
      nn-chess README
    </a>{' '}
    for the full design: goals, architecture, roadmap, and the deliberate
    constraints that keep the learning signal honest.
  </p>

  <div style="max-width: 600px; margin: 0 auto;">
    <Board client:only="react" />
  </div>
</BaseLayout>
