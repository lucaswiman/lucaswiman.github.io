---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Game from '../../../nn-chess/ui/Game.tsx';
---
<BaseLayout title="nn-chess" description="Browser chess that learns from your games" useMath={false}>
  <h1>nn-chess</h1>
  <p>
    Play against a neural-network agent that learns <em>solely</em> from the
    win/loss signal of games it plays against you — no opening books, no piece
    tables, no hand-coded evaluation. The agent starts out terrible and
    (hopefully) improves as it accumulates games. See the{' '}
    <a href="https://github.com/lucaswiman/lucaswiman.github.io/blob/main/nn-chess/README.md">
      nn-chess README
    </a>{' '}
    for the full design: goals, architecture, roadmap, and the deliberate
    constraints that keep the learning signal honest.
  </p>

  <div style="max-width: 620px; margin: 0 auto;">
    <Game client:only="react" />
  </div>
</BaseLayout>
